# Gemini API — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# FRED API — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_key_here

# Optional overrides
DATABASE_PATH=data/goldforecaster.db
GEMINI_MODEL=gemini-2.5-flash
# Per-task model chains (comma-separated; rotate on 429)
GEMINI_SUMMARIZE_MODEL=gemini-3.1-flash-lite
GEMINI_SUMMARIZE_MODELS=gemini-3.1-flash-lite,gemma-4-26b,gemma-4-31b,gemini-3.5-flash,gemini-3-flash,gemini-2.5-flash-lite,gemini-2.5-flash
GEMINI_FORECAST_MODEL=gemini-3.5-flash
GEMINI_FORECAST_MODELS=gemini-3.5-flash,gemini-3.1-flash-lite,gemini-2.5-flash
SUMMARIZE_BATCH_LIMIT=100
GEMINI_REQUEST_DELAY_SECONDS=8
GEMINI_RATE_LIMIT_COOLDOWN_SECONDS=30
GEMINI_MODEL_COOLDOWN_SECONDS=300
CLEAR_STALE_ARTICLES_ON_SUMMARIZE=true

# Telegram — https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Daily job schedule (Asia/Ho_Chi_Minh)
DAILY_JOB_HOUR=7
DAILY_JOB_MINUTE=0
DAILY_JOB_TIMEZONE=Asia/Ho_Chi_Minh

API_HOST=127.0.0.1
API_PORT=8000
